<Window x:Class="Banking_system.Windows.DepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Операції з карткою" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="20" Background="#141E30" BorderBrush="#38BDF8" BorderThickness="1" Padding="20">
        <StackPanel>
            <TextBlock Text="Операції з карткою" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBox x:Name="TxtCardNumber" materialDesign:HintAssist.Hint="Номер картки (16 цифр)" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" 
                     Margin="0,10" InputScope="Number"/>

            <ComboBox x:Name="CmbOperationType" materialDesign:HintAssist.Hint="Тип операції" 
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}" Foreground="White" 
                      Margin="0,10"/>

            <TextBox x:Name="TxtAmount" materialDesign:HintAssist.Hint="Сума (грн)" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Foreground="White" 
                     Margin="0,10" InputScope="Number"/>

            <StackPanel Orientation="Vertical" Margin="0,30,0,0">
                <Button x:Name="BtnDeposit" Content="ПОПОВНИТИ" Click="BtnDeposit_Click" 
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="#388E3C" BorderThickness="0" Margin="0,0,0,10"/>

                <Button x:Name="BtnWithdraw" Content="ЗНЯТИ ГРОШІ" Click="BtnWithdraw_Click" 
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="#D32F2F" BorderThickness="0" Margin="0,0,0,10"/>

                <Button Content="ЗАКРИТИ" Click="BtnClose_Click" 
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#888"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>