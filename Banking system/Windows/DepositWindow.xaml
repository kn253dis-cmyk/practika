<Window x:Class="Banking_system.Windows.DepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Операції з карткою" Height="580" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="25" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Padding="30">
        <StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <materialDesign:PackIcon Kind="WalletOutline" Width="30" Height="30" Foreground="#38BDF8" VerticalAlignment="Center"/>
                <TextBlock Text="Операції з карткою" FontSize="20" FontWeight="Bold" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBox x:Name="TxtCardNumber" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Номер картки"
                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                     materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="CreditCardOutline"
                     materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                     Foreground="White" FontSize="15" Margin="0,0,0,15" IsReadOnly="True"/>

            <ComboBox x:Name="CmbOperationType" 
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="55" Padding="15,0"
                      VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Тип операції"
                      materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                      materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                      materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                      Foreground="White" FontSize="15" Margin="0,0,0,15">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
                </ComboBox.Resources>
            </ComboBox>

            <TextBox x:Name="TxtAmount" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Сума (грн)"
                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                     materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                     materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="Cash"
                     Foreground="#38BDF8" FontWeight="Bold" FontSize="16" Margin="0,0,0,25" InputScope="Number"/>

            <StackPanel Orientation="Vertical">
                <Button x:Name="BtnDeposit" Content="ПОПОВНИТИ" Click="BtnDeposit_Click" 
                        Height="50" FontSize="15" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="12" 
                        Background="#10B981" BorderThickness="0" Margin="0,0,0,12"/>

                <Button x:Name="BtnWithdraw" Content="ЗНЯТИ ГРОШІ" Click="BtnWithdraw_Click" 
                        Height="50" FontSize="15" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="12" 
                        Background="#EF4444" BorderThickness="0" Margin="0,0,0,12"/>

                <Button Content="ЗАКРИТИ" Click="BtnClose_Click" 
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#94A3B8" Margin="0,10,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>