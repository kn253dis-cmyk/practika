<Page x:Class="Banking_system.Views.TransferPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Переказ коштів">

    <Page.Background>
        <SolidColorBrush Color="#0F172A"/>
    </Page.Background>

    <Grid>
        <Border Background="#1E293B" CornerRadius="25" BorderBrush="#334155" BorderThickness="1" 
                VerticalAlignment="Center" HorizontalAlignment="Center" Width="460" Padding="30,35">
            <StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Border Background="#3B82F6" Width="45" Height="45" CornerRadius="15" Margin="0,0,15,0">
                        <materialDesign:PackIcon Kind="SwapHorizontal" Width="30" Height="30" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Переказ коштів" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Швидко та безпечно" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <TextBox x:Name="TxtSenderCard"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Картка відправника"
                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="CreditCardOutline"
                         Foreground="#CBD5E1" CaretBrush="White" FontSize="16" IsReadOnly="True" Margin="0,0,0,10"/>

                <materialDesign:PackIcon Kind="ArrowDown" Foreground="#334155" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBox x:Name="TxtReceiverCard"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Номер картки отримувача"
                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="AccountCreditCardOutline"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Foreground="White" CaretBrush="White" FontSize="16" MaxLength="19" Margin="0,0,0,20"/>

                <TextBox x:Name="TxtAmount"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="60" Padding="15,0"
                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Сума переказу (₴)"
                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#3B82F6" BorderThickness="2"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="CashFast"
                         Foreground="#38BDF8" FontWeight="Bold" CaretBrush="#38BDF8" FontSize="20" Margin="0,0,0,20"/>

                <ComboBox x:Name="CmbPurposeCode"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="55" Padding="15,0"
                          VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Код призначення платежу"
                          materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                          materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                          materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                          Foreground="White" FontSize="15" Margin="0,0,0,20">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="1020 — Переказ особистих коштів" IsSelected="True" Foreground="White"/>
                    <ComboBoxItem Content="1030 — Оплата послуг" Foreground="White"/>
                    <ComboBoxItem Content="1040 — Оплата товарів" Foreground="White"/>
                    <ComboBoxItem Content="1010 — Благодійний внесок" Foreground="White"/>
                    <ComboBoxItem Content="1050 — Погашення кредиту" Foreground="White"/>
                    <ComboBoxItem Content="1090 — Інше призначення" Foreground="White"/>
                </ComboBox>

                <TextBox x:Name="TxtComment"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="80" Padding="15,12"
                         TextWrapping="Wrap" VerticalContentAlignment="Top"
                         materialDesign:HintAssist.Hint="Коментар до платежу (необов'язково)"
                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Foreground="White" CaretBrush="White" FontSize="15" MaxLength="200" Margin="0,0,0,30"/>

                <Button x:Name="BtnSubmitTransfer" Content="НАДІСЛАТИ КОШТИ" Height="55" FontSize="16" FontWeight="Bold"
                        Background="#3B82F6" BorderThickness="0" Foreground="White" 
                        materialDesign:ButtonAssist.CornerRadius="12" Click="BtnSubmitTransfer_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>