<Window x:Class="Banking_system.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Статистика" Height="680" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="#141E30" BorderBrush="#38BDF8" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Border Background="#1A2235" Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChartPie" Width="28" Height="28" Foreground="#38BDF8" Margin="0,0,10,0"/>
                    <TextBlock Text="Статистика по карті" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="25,20,25,10">
                <TextBlock x:Name="TxtCardNumber" Text="**** **** **** 0000" FontSize="16" Foreground="#BDBDBD" HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Grid Margin="0,0,15,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="ArrowUpCircle" Foreground="#4CAF50" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Grid>
                                    <TextBlock Text="Загальні доходи" FontSize="13" Foreground="#BDBDBD" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtTotalIncome" Text="+ 24 500 ₴" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="IncomeProgress" Value="100" Height="6" Background="#2A3040" Foreground="#4CAF50" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,15,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="ArrowDownCircle" Foreground="#FF5252" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Grid>
                                    <TextBlock Text="Загальні витрати" FontSize="13" Foreground="#BDBDBD" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtTotalExpense" Text="- 15 320 ₴" FontSize="14" FontWeight="Bold" Foreground="#FF5252" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="ExpenseProgress" Value="65" Height="6" Background="#2A3040" Foreground="#FF5252" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Column="1" Width="120" Height="120" HorizontalAlignment="Right">
                        <ItemsControl x:Name="PieChartControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path Fill="{Binding ColorBrush}" Data="{Binding Geometry}" Stroke="#141E30" StrokeThickness="2" Cursor="Hand">
                                        <Path.ToolTip>
                                            <ToolTip Background="#1A2235" Foreground="White" BorderBrush="#38BDF8" BorderThickness="1" Placement="Mouse">
                                                <TextBlock Text="{Binding ToolTipText}" FontWeight="SemiBold" FontSize="14"/>
                                            </ToolTip>
                                        </Path.ToolTip>
                                    </Path>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Ellipse Width="80" Height="80" Fill="#141E30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <materialDesign:PackIcon Kind="Wallet" Width="30" Height="30" Foreground="#38BDF8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <Separator Background="#333" Margin="0,20,0,10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="25,0,25,20">
                <TextBlock Text="Деталізація витрат" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CategoriesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="{Binding ColorHex}" Width="40" Height="40" CornerRadius="10">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15" Foreground="White"/>
                                        <TextBlock Text="{Binding PercentageText}" FontSize="12" Foreground="#888"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding TotalText}" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <Border Grid.Row="3" Background="#1A2235" CornerRadius="0,0,20,20">
                <Button Content="ЗАКРИТИ" Width="150" Height="40" 
                        Style="{StaticResource MaterialDesignFlatDarkBgButton}" 
                        Background="#2A050A" Foreground="White"
                        Click="BtnClose_Click" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>