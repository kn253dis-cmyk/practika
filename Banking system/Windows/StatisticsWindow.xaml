<Window x:Class="Banking_system.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Статистика" Height="650" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="#141E30" BorderBrush="#38BDF8" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Border Background="#1A2235" Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChartPie" Width="28" Height="28" Foreground="#38BDF8" Margin="0,0,10,0"/>
                    <TextBlock Text="Статистика по карті" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="25,25,25,10">
                <TextBlock x:Name="TxtCardNumber" Text="**** **** **** 0000" FontSize="16" Foreground="#BDBDBD" HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="ArrowUpCircle" Foreground="#4CAF50" Width="30" Height="30" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="Загальні доходи" FontSize="14" Foreground="#BDBDBD"/>
                        <ProgressBar x:Name="IncomeProgress" Value="100" Height="8" Background="#2A3040" Foreground="#4CAF50" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTotalIncome" Grid.Column="2" Text="+ 24 500 ₴" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="ArrowDownCircle" Foreground="#FF5252" Width="30" Height="30" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="Загальні витрати" FontSize="14" Foreground="#BDBDBD"/>
                        <ProgressBar x:Name="ExpenseProgress" Value="65" Height="8" Background="#2A3040" Foreground="#FF5252" materialDesign:TransitionAssist.DisableTransitions="True" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTotalExpense" Grid.Column="2" Text="- 15 320 ₴" FontSize="16" FontWeight="Bold" Foreground="#FF5252" VerticalAlignment="Center"/>
                </Grid>

                <Separator Background="#333" Margin="0,10"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="25,0,25,20">
                <TextBlock Text="Категорії витрат у цьому місяці" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CategoriesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="{Binding ColorHex}" Width="40" Height="40" CornerRadius="10">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15" Foreground="White"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="12" Foreground="#888"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding TotalText}" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <Border Grid.Row="3" Background="#1A2235" CornerRadius="0,0,20,20">
                <Button Content="ЗАКРИТИ" Width="150" Height="40" 
                        Style="{StaticResource MaterialDesignFlatDarkBgButton}" 
                        Background="#2A050A" Foreground="White"
                        Click="BtnClose_Click" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>