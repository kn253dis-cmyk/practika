<Window x:Class="Banking_system.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Banking_system"
        mc:Ignorable="d"
        Title="Вхід у систему" Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True" Background="#0F172A">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                        <GradientStop Color="#0F2027" Offset="0.0" />
                        <GradientStop Color="#203A43" Offset="0.5" />
                        <GradientStop Color="#2C5364" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <Border Background="Transparent" BorderBrush="#38BDF8" BorderThickness="2" CornerRadius="20" Padding="20" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <materialDesign:PackIcon Kind="BankOutline" Width="80" Height="80" Foreground="#38BDF8" />
                    </Border>
                    <TextBlock Text="Національний" FontSize="36" FontWeight="Light" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="БАНК" FontSize="42" FontWeight="Bold" Foreground="#38BDF8" HorizontalAlignment="Center" Margin="0,-10,0,15"/>
                    <TextBlock Text="Твій капітал під надійним захистом" FontSize="15" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#1E293B">
                <Grid>
                    <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                            Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#64748B" ToolTip="Закрити" Click="BtnClose_Click">
                        <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="40,0">
                        <TextBlock Text="З поверненням!" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,5" />
                        <TextBlock Text="Увійдіть до свого облікового запису" FontSize="14" Foreground="#94A3B8" Margin="0,0,0,35" />

                        <TextBox x:Name="LoginBox" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0" 
                                 VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Електронна пошта" 
                                 materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                 materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" 
                                 materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                 materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                                 Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,20" />

                        <PasswordBox x:Name="PassBox" 
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Height="55" Padding="15,0" 
                                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Пароль" 
                                     materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"  
                                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" 
                                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                     materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                                     Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,5" />

                        <Button Content="Забули пароль?" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#38BDF8" 
                                HorizontalAlignment="Right" Padding="0" Height="Auto" Margin="0,0,0,30" />

                        <Button Content="УВІЙТИ" Height="50" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="12" 
                                Background="#38BDF8" BorderThickness="0" Foreground="#0F172A" Margin="0,0,0,25" Click="logInButt_Click" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Ще не маєте акаунту?" Foreground="#94A3B8" VerticalAlignment="Center" />
                            <Button x:Name="BtnOpenRegister" Content="Відкрити рахунок" Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#38BDF8" FontWeight="Bold" Padding="5,0,0,0" Height="Auto" Click="BtnOpenRegister_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>