<Window x:Class="Banking_system.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Banking_system"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#1A1A2E" Offset="0.0" />
                <GradientStop Color="#16213E" Offset="0.5" />
                <GradientStop Color="#0F3460" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2" Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#BDBDBD" ToolTip="Закрити" Click="BtnClose_Click">
                <materialDesign:PackIcon Kind="WindowClose" Width="24" Height="24" />
            </Button>

            <materialDesign:Card UniformCornerRadius="20" Background="#1A2235" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30,40" Width="360" materialDesign:ElevationAssist.Elevation="Dp8">
                <StackPanel>

                    <materialDesign:PackIcon Kind="Bank" Width="70" Height="70" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,15" />
                    <TextBlock Text="Національний Банк" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,5" />
                    <TextBlock Text="Безпечний вхід у систему" FontSize="14" HorizontalAlignment="Center" Foreground="#A0A0A0" Margin="0,0,0,30" />

                    <TextBox x:Name="LoginBox" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="10,5" VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Email" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.HintPaddingBrush="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" materialDesign:TextFieldAssist.UnderlineBrush="White" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,15" />

                    <PasswordBox x:Name="PassBox" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Height="50" Padding="10,5" VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Ваш пароль" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.HintPaddingBrush="#1A2235"  materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" materialDesign:TextFieldAssist.UnderlineBrush="White" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,10" />

                    <Grid Margin="0,5,0,25">
                        <CheckBox Content="Запам'ятати мене" Foreground="#BDBDBD" HorizontalAlignment="Left" />
                        <Button Content="Забули пароль?" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Right" Padding="0" Height="Auto" />
                    </Grid>

                    <Button Content="УВІЙТИ" Height="45" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,0,20" Click="logInButt_Click" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="УВІЙТИ" 
                                Height="50" 
                                FontSize="16" 
                                FontWeight="Bold"
                                materialDesign:ButtonAssist.CornerRadius="15"
                                Margin="0,0,0,20" />

                                                    <Button Content="ТЕСТ: ДО ІСТОРІЇ ОПЕРАЦІЙ" 
                                Height="45" 
                                FontSize="14" 
                                FontWeight="Bold"
                                Background="#E74C3C"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="15"
                                Margin="0,0,0,20"
                                Click="BtnTestHistory_Click"/>
                        <TextBlock Text="Стати клієнтом банку?" Foreground="#A0A0A0" VerticalAlignment="Center" />
                        <Button x:Name="BtnOpenRegister" Content="Відкрити рахунок" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontWeight="Bold" Padding="5,0,0,0" Height="Auto" Click="BtnOpenRegister_Click" />
                    </StackPanel>

                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Border>
</Window>