<Page x:Class="Banking_system.Views.TransactionHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="850"
      MinWidth="750"
      Title="Історія транзакцій" Background="#0F172A"
      TextOptions.TextFormattingMode="Display" 
      TextOptions.TextRenderingMode="ClearType"
      UseLayoutRounding="True" 
      SnapsToDevicePixels="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#1E293B" Width="40" Height="40" CornerRadius="12" Margin="0,0,15,0">
                        <materialDesign:PackIcon Kind="History" Width="26" Height="26" Foreground="#38BDF8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Історія транзакцій" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Усі ваші операції та перекази" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">

                    <DatePicker x:Name="DpSearchDate" Width="170" Height="45" Margin="0,0,8,0"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" Padding="15,0" 
                                VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Пошук за датою" 
                                materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" 
                                materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                Foreground="White" FontSize="14"
                                SelectedDateChanged="DpSearchDate_SelectedDateChanged"/>

                    <Button x:Name="BtnClearDate" Click="BtnClearDate_Click" 
                            Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Foreground="#EF4444" Width="35" Height="45" Padding="0" 
                            Visibility="Collapsed" Margin="0,0,8,0" ToolTip="Скинути дату пошуку">
                        <materialDesign:PackIcon Kind="Close" Width="22" Height="22"/>
                    </Button>

                    <Button x:Name="BtnToggleSort" Click="BtnToggleSort_Click"
                            Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"
                            Background="#1E293B" BorderBrush="#334155" Foreground="#38BDF8"
                            Width="45" Height="45" ToolTip="Спочатку нові"
                            materialDesign:ButtonAssist.CornerRadius="12">
                        <materialDesign:PackIcon x:Name="IconSort" Kind="ArrowDown" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Background="#1E293B" CornerRadius="12" Padding="15,12" BorderBrush="#334155" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#F59E0B" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="Подвійний клік по запису відкриє електронну квитанцію" Foreground="#CBD5E1" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Background="#1E293B" CornerRadius="20" BorderBrush="#334155" BorderThickness="1" Padding="10">
            <ListBox x:Name="TransactionsList" MouseDoubleClick="TransactionsList_MouseDoubleClick" 
                     BorderThickness="0" Background="Transparent" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Padding" Value="15"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}" CornerRadius="12" 
                                            BorderBrush="#334155" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A3B54"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#38BDF8"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A3B54"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#38BDF8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="45" Height="45" CornerRadius="12" Background="#0F172A" Margin="0,0,15,0">
                                <materialDesign:PackIcon Kind="ReceiptTextOutline" Width="24" Height="24" Foreground="#38BDF8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                <TextBlock Text="{Binding Text}" FontWeight="SemiBold" FontSize="15" Foreground="White" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="ID: " FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding Id}" FontSize="12" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Date, StringFormat='HH:mm'}" FontSize="12" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
        </Border>
    </Grid>
</Page>