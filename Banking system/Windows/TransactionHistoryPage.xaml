<Page x:Class="Banking_system.Views.TransactionHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Історія транзакцій" Background="#F4F6F8"
      TextOptions.TextFormattingMode="Display" 
      TextOptions.TextRenderingMode="ClearType"
      UseLayoutRounding="True" 
      SnapsToDevicePixels="True">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Історія транзакцій" FontSize="24" FontWeight="SemiBold" Foreground="#2C3E50"/>
            <TextBlock Text="Подвійний клік по запису для відправки електронної квитанції" FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">

            <Border Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#BDC3C7" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="10">
                <ListBox x:Name="TransactionsList" MouseDoubleClick="TransactionsList_MouseDoubleClick" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EBF5FB"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F8F9F9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ECF0F1" BorderThickness="0,0,0,1" Margin="2,0,2,5" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="{Binding Text}" FontWeight="Bold" FontSize="16" Foreground="#34495E" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Id}" FontSize="12" Foreground="#95A5A6" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}" FontSize="13" Foreground="#7F8C8D" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </Border>
        </Grid>
    </Grid>
</Page>