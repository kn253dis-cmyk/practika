<Window x:Class="Banking_system.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Відкриття рахунку" Height="680" Width="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True" Background="#0F172A">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                        <GradientStop Color="#0F2027" Offset="0.0" />
                        <GradientStop Color="#203A43" Offset="0.5" />
                        <GradientStop Color="#2C5364" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <Border Background="Transparent" BorderBrush="#38BDF8" BorderThickness="2" CornerRadius="20" Padding="15" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <materialDesign:PackIcon Kind="CreditCardCheckOutline" Width="70" Height="70" Foreground="#38BDF8" />
                    </Border>

                    <TextBlock Text="Національний" FontSize="32" FontWeight="Light" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="БАНК" FontSize="38" FontWeight="Bold" Foreground="#38BDF8" HorizontalAlignment="Center" Margin="0,-5,0,30"/>

                    <StackPanel Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#38BDF8" Width="20" Height="20" Margin="0,0,10,0"/>
                            <TextBlock Text="Безкоштовне відкриття" Foreground="#E2E8F0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#38BDF8" Width="20" Height="20" Margin="0,0,10,0"/>
                            <TextBlock Text="Кешбек на всі покупки" Foreground="#E2E8F0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#38BDF8" Width="20" Height="20" Margin="0,0,10,0"/>
                            <TextBlock Text="Перекази без комісій" Foreground="#E2E8F0" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#1E293B" Padding="40,20">
                <Grid>
                    <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-20,-10,0,0" 
                            Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#64748B" ToolTip="Закрити" Click="BtnClose_Click">
                        <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
                    </Button>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Створити акаунт" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,5" />
                        <TextBlock Text="Заповніть дані для відкриття рахунку" FontSize="14" Foreground="#94A3B8" Margin="0,0,0,25" />

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TxtFullName" Grid.Column="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="15,0" 
                                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="ПІБ (через пробіл)" 
                                     materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                     Foreground="White" CaretBrush="White" FontSize="14"/>

                            <TextBox x:Name="TxtPhone" Grid.Column="2"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="15,0" 
                                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Номер телефону" 
                                     materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                     Foreground="White" CaretBrush="White" FontSize="14" />
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TxtEmail" Grid.Column="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="15,0" 
                                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Email адреса" 
                                     materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                     Foreground="White" CaretBrush="White" FontSize="14"/>

                            <TextBox x:Name="TxtIpn" Grid.Column="2"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="15,0" 
                                     VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="ІПН (10 цифр)" 
                                     materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                     materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                     materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                     Foreground="White" CaretBrush="White" FontSize="14" />
                        </Grid>

                        <ComboBox x:Name="CmbCardType" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                                  Height="50" Padding="15,0" 
                                  VerticalContentAlignment="Center" 
                                  materialDesign:HintAssist.Hint="Оберіть тип першої картки" 
                                  materialDesign:HintAssist.Background="#1E293B" 
                                  materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                  materialDesign:HintAssist.Foreground="#94A3B8" 
                                  materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                  materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" 
                                  BorderBrush="#334155" 
                                  Foreground="White" FontSize="14" Margin="0,0,0,20">

                            <ComboBox.Resources>
                                <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
                            </ComboBox.Resources>

                            <ComboBoxItem Content="Дебетова" IsSelected="True" Foreground="White" />
                            <ComboBoxItem Content="Кредитна" Foreground="White" />
                            <ComboBoxItem Content="Юніорська" Foreground="White" />
                        </ComboBox>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="TxtPassword" Grid.Column="0"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Height="50" Padding="15,0" 
                                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Придумайте пароль" 
                                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                         Foreground="White" CaretBrush="White" FontSize="14"/>

                            <PasswordBox x:Name="TxtConfirmPassword" Grid.Column="2"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Height="50" Padding="15,0" 
                                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Повторіть пароль" 
                                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                                         Foreground="White" CaretBrush="White" FontSize="14"/>
                        </Grid>

                        <Button x:Name="BtnRegister" Content="ВІДКРИТИ РАХУНОК" Height="50" FontSize="16" FontWeight="Bold" 
                                materialDesign:ButtonAssist.CornerRadius="10" Background="#38BDF8" BorderThickness="0" 
                                Foreground="#0F172A" Margin="0,0,0,20" Click="BtnRegister_Click" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Вже є рахунок?" Foreground="#94A3B8" VerticalAlignment="Center" />
                            <Button x:Name="BtnBackToLogin" Content="Увійти" Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#38BDF8" FontWeight="Bold" Padding="5,0,0,0" Height="Auto" Click="BtnBackToLogin_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>