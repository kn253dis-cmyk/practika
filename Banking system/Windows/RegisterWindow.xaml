<Window x:Class="Banking_system.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#1A1A2E" Offset="0.0" />
                <GradientStop Color="#16213E" Offset="0.5" />
                <GradientStop Color="#0F3460" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2" Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#BDBDBD" ToolTip="Закрити" Click="BtnClose_Click">
                <materialDesign:PackIcon Kind="WindowClose" Width="24" Height="24" />
            </Button>

            <materialDesign:Card UniformCornerRadius="20" Background="#1A2235" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25,30,25,30" Width="360" materialDesign:ElevationAssist.Elevation="Dp8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="540">
                    <StackPanel Margin="5,0,5,0">

                        <materialDesign:PackIcon Kind="Bank" Width="60" Height="60" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,10" />
                        <TextBlock Text="Національний Банк" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,3" />
                        <TextBlock Text="Відкриття рахунку" FontSize="14" HorizontalAlignment="Center" Foreground="#A0A0A0" Margin="0,0,0,25" />

                        <TextBox x:Name="TxtFullName" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="15,10" materialDesign:HintAssist.Hint="ПІБ" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,15" />
                        <TextBox x:Name="TxtPhone" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="15,10" materialDesign:HintAssist.Hint="Телефон" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,15" />
                        <TextBox x:Name="TxtIpn" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="15,10" materialDesign:HintAssist.Hint="ІПН" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,15" />

                        <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="10" Background="#1A2235" Margin="0,0,0,15">
                            <ComboBox x:Name="CmbCardType" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="15">
                                <ComboBox.Template>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Grid Background="Transparent">
                                                            <materialDesign:PackIcon Kind="ChevronDown" Foreground="#BDBDBD" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="15,10,30,10" VerticalAlignment="Center" HorizontalAlignment="Left" />

                                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                <Border x:Name="DropDownBorder" Background="#1A2235" BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="10" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                    <ScrollViewer SnapsToDevicePixels="True">
                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </ComboBox.Template>

                                <ComboBoxItem Content="Дебетова" IsSelected="True" Foreground="White" Background="#1A2235" Padding="15,10"/>
                                <ComboBoxItem Content="Кредитна" Foreground="White" Background="#1A2235" Padding="15,10"/>
                                <ComboBoxItem Content="Юніорська" Foreground="White" Background="#1A2235" Padding="15,10"/>
                            </ComboBox>
                        </Border>

                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Padding="15,10" materialDesign:HintAssist.Hint="Пароль" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,15" />
                        <PasswordBox x:Name="TxtConfirmPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Padding="15,10" materialDesign:HintAssist.Hint="Підтвердження" materialDesign:HintAssist.Background="#1A2235" materialDesign:HintAssist.Foreground="#BDBDBD" materialDesign:TextFieldAssist.TextFieldCornerRadius="10" BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,25" />

                        <Button x:Name="BtnRegister" Content="ЗАРЕЄСТРУВАТИСЯ" Height="45" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,0,20" Click="BtnRegister_Click" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock Text="Вже є рахунок?" Foreground="#A0A0A0" VerticalAlignment="Center" />
                            <Button x:Name="BtnBackToLogin" Content="Увійти" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" FontWeight="Bold" Padding="5,0,0,0" Height="Auto" Click="BtnBackToLogin_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Border>
</Window>