<Window x:Class="Banking_system.Views.ReceiptConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Надсилання квитанції" Height="260" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FFFFFF">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Деталі відправлення" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,10"/>

        <TextBlock x:Name="TxtInfo" Grid.Row="1" FontSize="13" Foreground="#34495E" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Електронна пошта отримувача:" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtEmail" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1" FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Скасувати" Click="BtnCancel_Click" Grid.Column="0" Margin="0,0,5,0" Padding="10" Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="0"/>
            <Button Content="Надіслати" Click="BtnSend_Click" Grid.Column="1" Margin="5,0,0,0" Padding="10" Background="#27AE60" Foreground="White" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>