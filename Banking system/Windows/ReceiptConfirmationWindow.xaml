<Window x:Class="Banking_system.Views.ReceiptConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Надсилання квитанції" Height="820" Width="680" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="False" 
        Background="#0F172A"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#334155" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <materialDesign:PackIcon Kind="ReceiptTextCheckOutline" Width="26" Height="26" Foreground="#38BDF8" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Електронна квитанція" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#64748B" 
                            ToolTip="Закрити" Click="BtnCancel_Click" Width="36" Height="36">
                        <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#0F172A" Padding="15">
                <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <wv2:WebView2 x:Name="ReceiptBrowser" />
                </Border>
            </Border>

            <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="25">
                <StackPanel>
                    <TextBlock Text="Бажаєте надіслати копію на пошту?" FontSize="14" Foreground="#94A3B8" Margin="0,0,0,15"/>

                    <TextBox x:Name="TxtEmail" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0" 
                             VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Введіть Email отримувача" 
                             materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B" 
                             materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12" 
                             materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155" 
                             materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                             Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,20" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="СКАСУВАТИ" Click="BtnCancel_Click" Grid.Column="1" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#94A3B8" BorderBrush="#334155" BorderThickness="2" 
                                materialDesign:ButtonAssist.CornerRadius="12" Width="140" Height="45" Margin="0,0,15,0" Cursor="Hand"/>

                        <Button x:Name="BtnSend" Click="BtnSend_Click" Grid.Column="2" 
                                Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" BorderThickness="0" 
                                materialDesign:ButtonAssist.CornerRadius="12" Width="160" Height="45" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="SendOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Text="НАДІСЛАТИ" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#0F172A"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>