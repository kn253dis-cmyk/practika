<Window x:Class="Banking_system.Views.ReceiptConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Надсилання квитанції" Height="820" Width="680" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="False" 
        Background="#1A1A2E"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#1A1A2E" Offset="0.0" />
                <GradientStop Color="#16213E" Offset="0.5" />
                <GradientStop Color="#0F3460" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Перевірка та надсилання квитанції" FontWeight="Bold" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0" Padding="0" Height="30" Width="30" Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#BDBDBD" ToolTip="Закрити" Click="BtnCancel_Click">
                    <materialDesign:PackIcon Kind="WindowClose" Width="24" Height="24" />
                </Button>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#1A2235" BorderThickness="3" Background="#1A1A2E" Margin="0,0,0,20">
                <wv2:WebView2 x:Name="ReceiptBrowser" />
            </Border>

            <materialDesign:Card Grid.Row="2" UniformCornerRadius="15" Background="#1A2235" Padding="25" materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>

                    <TextBox x:Name="TxtEmail" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="50" Padding="10,5" VerticalContentAlignment="Center" 
                             materialDesign:HintAssist.Hint="Електронна пошта отримувача" 
                             materialDesign:HintAssist.Background="#1A2235" 
                             materialDesign:HintAssist.HintPaddingBrush="#1A2235" 
                             materialDesign:HintAssist.Foreground="#BDBDBD" 
                             materialDesign:TextFieldAssist.TextFieldCornerRadius="10" 
                             materialDesign:TextFieldAssist.UnderlineBrush="White" 
                             BorderBrush="#BDBDBD" Foreground="White" CaretBrush="White" FontSize="15" Margin="0,0,0,20" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="СКАСУВАТИ" Click="BtnCancel_Click" Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#BDBDBD" BorderBrush="#BDBDBD" materialDesign:ButtonAssist.CornerRadius="10" Width="140" Height="45" Margin="0,0,15,0" Cursor="Hand"/>

                        <Button x:Name="BtnSend" Content="НАДІСЛАТИ" Click="BtnSend_Click" Grid.Column="2" Background="#00E676" Foreground="#1A1A2E" FontWeight="Bold" BorderThickness="0" materialDesign:ButtonAssist.CornerRadius="10" Width="160" Height="45" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Border>
</Window>