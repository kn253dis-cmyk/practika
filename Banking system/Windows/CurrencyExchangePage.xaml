<Page x:Class="Banking_system.Pages.CurrencyExchangePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Banking_system.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CurrencyExchangePage" Background="White">

    <Grid Margin="20">
        <StackPanel MaxWidth="450" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Обмін та конвертація валюти" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="Black"/>

            <TextBlock Text="Картка списання (Гривнева):" FontWeight="SemiBold" Margin="0,10,0,5"/>
            <ComboBox x:Name="CboSourceCard" Height="40" VerticalContentAlignment="Center" SelectionChanged="CboSourceCard_SelectionChanged"/>

            <TextBlock Text="Валютна картка зарахування:" FontWeight="SemiBold" Margin="0,15,0,5"/>
            <TextBox x:Name="TxtTargetCard" Height="40" IsReadOnly="True" Background="#F5F5F5" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Цільова валюта:" FontWeight="SemiBold" Margin="0,15,0,5"/>
            <ComboBox x:Name="CboCurrency" Height="40" VerticalContentAlignment="Center" SelectionChanged="CboCurrency_SelectionChanged">
                <ComboBoxItem Content="USD"/>
                <ComboBoxItem Content="EUR"/>
                <ComboBoxItem Content="PLN"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                <TextBlock Text="Поточний курс купівлі: " FontSize="14"/>
                <TextBlock x:Name="LblCurrentRate" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="Green"/>
                <TextBlock Text=" ₴" FontSize="14"/>
            </StackPanel>

            <TextBlock Text="Сума у валюті (скільки хочете придбати):" FontWeight="SemiBold" Margin="0,10,0,5"/>
            <TextBox x:Name="TxtAmount" Height="40" VerticalContentAlignment="Center" PreviewTextInput="TxtAmount_PreviewTextInput" TextChanged="TxtAmount_TextChanged"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
                <TextBlock Text="До сплати: " FontSize="14"/>
                <TextBlock x:Name="LblTotalPayable" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="Red"/>
                <TextBlock Text=" ₴" FontSize="14"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnCancel" Grid.Column="0" Content="Назад" Click="BtnCancel_Click" Margin="0,0,5,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                <Button x:Name="BtnConfirmExchange" Grid.Column="1" Content="Підтвердити" Click="BtnConfirmExchange_Click" Margin="5,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Page>