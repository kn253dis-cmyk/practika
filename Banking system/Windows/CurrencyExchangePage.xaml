<Page x:Class="Banking_system.Pages.CurrencyExchangePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      Title="Обмін валют">

    <Page.Background>
        <SolidColorBrush Color="#0F172A"/>
    </Page.Background>

    <Grid>
        <Border Background="#1E293B" CornerRadius="25" BorderBrush="#334155" BorderThickness="1" 
                VerticalAlignment="Center" HorizontalAlignment="Center" Width="460" Padding="30,35">
            <StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Border Background="#38BDF8" Width="45" Height="45" CornerRadius="15" Margin="0,0,15,0">
                        <materialDesign:PackIcon Kind="SwapHorizontalBold" Width="30" Height="30" Foreground="#0F172A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Обмін валют" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Швидка конвертація" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <ComboBox x:Name="CboSourceCard"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="55" Padding="15,0"
                          VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Картка списання (Гривнева)"
                          materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                          materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                          materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                          Foreground="White" FontSize="15" Margin="0,0,0,15" SelectionChanged="CboSourceCard_SelectionChanged">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
                    </ComboBox.Resources>
                </ComboBox>

                <materialDesign:PackIcon Kind="ArrowDown" Foreground="#334155" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBox x:Name="TxtTargetCard"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                         VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Валютна картка зарахування"
                         materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                         materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                         materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True" materialDesign:TextFieldAssist.LeadingIcon="CreditCardOutline"
                         Foreground="#CBD5E1" CaretBrush="White" FontSize="15" IsReadOnly="True" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CboCurrency" Grid.Column="0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="55" Padding="15,0"
                              VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Валюта"
                              materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                              materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                              materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#334155"
                              Foreground="White" FontSize="15" SelectionChanged="CboCurrency_SelectionChanged">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1E293B"/>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="USD" Foreground="White"/>
                        <ComboBoxItem Content="EUR" Foreground="White"/>
                        <ComboBoxItem Content="PLN" Foreground="White"/>
                        <ComboBoxItem Content="GBP" Foreground="White"/>
                        <ComboBoxItem Content="XAU" Foreground="White"/>
                        <ComboBoxItem Content="XAG" Foreground="White"/>
                    </ComboBox>

                    <TextBox x:Name="TxtAmount" Grid.Column="2"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="55" Padding="15,0"
                             VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Сума покупки"
                             materialDesign:HintAssist.Background="#1E293B" materialDesign:HintAssist.HintPaddingBrush="#1E293B"
                             materialDesign:HintAssist.Foreground="#94A3B8" materialDesign:TextFieldAssist.TextFieldCornerRadius="12"
                             materialDesign:TextFieldAssist.UnderlineBrush="#38BDF8" BorderBrush="#38BDF8" BorderThickness="2"
                             Foreground="#38BDF8" FontWeight="Bold" CaretBrush="#38BDF8" FontSize="18" 
                             PreviewTextInput="TxtAmount_PreviewTextInput" TextChanged="TxtAmount_TextChanged"/>
                </Grid>

                <Border Background="#0F172A" CornerRadius="12" Padding="15" Margin="0,0,0,25" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Поточний курс:" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="LblCurrentRate" Text="0.00" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock Text=" ₴" FontSize="14" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#334155" Margin="0,0,0,10"/>

                        <Grid>
                            <TextBlock Text="До сплати:" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="LblTotalPayable" Text="0.00" FontSize="16" FontWeight="Bold" Foreground="#EF4444"/>
                                <TextBlock Text=" ₴" FontSize="16" FontWeight="Bold" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnCancel" Grid.Column="0" Content="СКАСУВАТИ" Click="BtnCancel_Click" 
                            Height="50" FontSize="14" FontWeight="Bold" Foreground="#94A3B8"
                            Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="#334155" BorderThickness="2"
                            materialDesign:ButtonAssist.CornerRadius="12"/>

                    <Button x:Name="BtnConfirmExchange" Grid.Column="2" Content="ПІДТВЕРДИТИ" Click="BtnConfirmExchange_Click" 
                            Height="50" FontSize="14" FontWeight="Bold" Foreground="#0F172A"
                            Background="#38BDF8" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="12"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Page>