<Window x:Class="Banking_system.Windows.CreditPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Вибір кредитного плану" Height="550" Width="950"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="15" Background="#141E30" BorderBrush="#243B55" BorderThickness="2" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,25,20,10">
                <TextBlock Text="ОБЕРІТЬ КРЕДИТНИЙ ПЛАН" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Підберіть ідеальні умови кредитування для ваших потреб" FontSize="14" Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <Grid x:Name="CardsGrid" Grid.Row="1" Margin="25,10" IsEnabled="False">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card x:Name="CardMicro" Grid.Column="0" Background="#1E2A38" UniformCornerRadius="12" Margin="10" Padding="0" Cursor="Hand" MouseLeftButtonUp="CardMicro_Click" materialDesign:ElevationAssist.Elevation="Dp4" BorderThickness="0">
                    <StackPanel Margin="20">
                        <materialDesign:PackIcon Kind="FlashOutline" Foreground="#38EF7D" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                        <TextBlock Text="Мікрозайм" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Швидкі кошти" FontSize="13" Foreground="#38EF7D" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Separator Background="#2C3E50" Margin="0,0,0,15"/>

                        <TextBlock Text="Кредитний ліміт" FontSize="12" Foreground="#90A4AE" HorizontalAlignment="Center"/>
                        <TextBlock Text="10 000 ₴" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="CalendarClock" Foreground="#BDBDBD" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                            <TextBlock Text="Пільговий період: " Foreground="#BDBDBD" FontSize="13"/>
                            <TextBlock Text="1 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#FF8A8A" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                            <TextBlock Text="Штраф: " Foreground="#FF8A8A" FontSize="13"/>
                            <TextBlock Text="10% / міс." Foreground="#FF8A8A" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardStandard" Grid.Column="1" Background="#243447" UniformCornerRadius="12" Margin="10" Padding="0" Cursor="Hand" MouseLeftButtonUp="CardStandard_Click" materialDesign:ElevationAssist.Elevation="Dp8" BorderBrush="#3498DB" BorderThickness="0">
                    <Grid>
                        <Border Background="#3498DB" CornerRadius="5,5,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Padding="8,3" Margin="0,0,0,0">
                            <TextBlock Text="ПОПУЛЯРНИЙ" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <StackPanel Margin="20,40,20,20">
                            <materialDesign:PackIcon Kind="CreditCardCheckOutline" Foreground="#3498DB" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,5,0,10"/>
                            <TextBlock Text="Стандартний" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Оптимальний вибір" FontSize="13" Foreground="#3498DB" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <Separator Background="#2C3E50" Margin="0,0,0,15"/>

                            <TextBlock Text="Кредитний ліміт" FontSize="12" Foreground="#90A4AE" HorizontalAlignment="Center"/>
                            <TextBlock Text="50 000 ₴" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="CalendarClock" Foreground="#BDBDBD" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                                <TextBlock Text="Пільговий період: " Foreground="#BDBDBD" FontSize="13"/>
                                <TextBlock Text="3 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#FF8A8A" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                                <TextBlock Text="Штраф: " Foreground="#FF8A8A" FontSize="13"/>
                                <TextBlock Text="8% / міс." Foreground="#FF8A8A" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardPremium" Grid.Column="2" Background="#1E2A38" UniformCornerRadius="12" Margin="10" Padding="0" Cursor="Hand" MouseLeftButtonUp="CardPremium_Click" materialDesign:ElevationAssist.Elevation="Dp4" BorderThickness="0">
                    <StackPanel Margin="20">
                        <materialDesign:PackIcon Kind="DiamondOutline" Foreground="#F1C40F" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                        <TextBlock Text="Преміум Максимум" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Для великих покупок" FontSize="13" Foreground="#F1C40F" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Separator Background="#2C3E50" Margin="0,0,0,15"/>

                        <TextBlock Text="Кредитний ліміт" FontSize="12" Foreground="#90A4AE" HorizontalAlignment="Center"/>
                        <TextBlock Text="250 000 ₴" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="CalendarClock" Foreground="#BDBDBD" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                            <TextBlock Text="Пільговий період: " Foreground="#BDBDBD" FontSize="13"/>
                            <TextBlock Text="6 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#FF8A8A" VerticalAlignment="Center" Margin="0,0,5,0" Width="18" Height="18"/>
                            <TextBlock Text="Штраф: " Foreground="#FF8A8A" FontSize="13"/>
                            <TextBlock Text="6% / міс." Foreground="#FF8A8A" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <Border x:Name="PanelInfo" Grid.Row="2" Background="#1F1515" Margin="35,5,35,25" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ShieldAlertOutline" Foreground="#FF4C4C" Margin="0,0,8,0" VerticalAlignment="Center" Width="20" Height="20"/>
                            <TextBlock Text="Важлива інформація про погашення та безпеку" FontWeight="Bold" FontSize="14" Foreground="#FF4C4C" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="За 3 дні до закінчення пільгового періоду Ви отримаєте нагадування на Email. Якщо борг не буде погашено вчасно, щомісяця нараховуватиметься штрафний відсоток." TextWrapping="Wrap" Foreground="#CFD8DC" FontSize="12" Margin="0,0,0,5" LineHeight="18"/>
                        <TextBlock Text="Увага! При ігноруванні боргу та відсутності платежів більше 2-х місяців підряд Ваша кредитна картка буде АВТОМАТИЧНО ЗАБЛОКОВАНА." TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#FF8A8A" FontSize="12"/>

                        <CheckBox x:Name="ChkAgreement" Content="Я ознайомлений(а) та погоджуюсь з умовами кредитування" Foreground="#90A4AE" FontWeight="Bold" Margin="0,15,0,0" Cursor="Hand"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Продовжити" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Background="#3498DB" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center" Height="45" Padding="20,0" Click="BtnContinue_Click"/>
                </Grid>
            </Border>

            <Border x:Name="PanelAction" Grid.Row="2" Background="#1A2235" Margin="35,5,35,25" CornerRadius="12" Padding="15" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="ОФОРМИТИ КРЕДИТ" Click="BtnSubmit_Click" Width="250" Height="45" Background="#3498DB" Foreground="#141E30" FontWeight="Bold" FontSize="16" materialDesign:ButtonAssist.CornerRadius="8" BorderThickness="0" Margin="0,0,20,0" Cursor="Hand"/>
                    <Button Content="Скасувати" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#546E7A" Height="45" Padding="20,0" Click="BtnCancel_Click" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>