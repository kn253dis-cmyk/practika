<Window x:Class="Banking_system.Windows.CreditPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Вибір кредитного плану" Height="620" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button x:Name="BtnClose_click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                    Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="#64748B" ToolTip="Закрити" Click="BtnCancel_Click">
                <materialDesign:PackIcon Kind="Close" Width="24" Height="24" />
            </Button>
            <StackPanel Grid.Row="0" Margin="0,30,0,10">
                <TextBlock Text="КРЕДИТНІ ПЛАНИ" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Оберіть ідеальні умови кредитування для ваших потреб" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <Grid x:Name="CardsGrid" Grid.Row="1" Margin="30,10,30,20" IsEnabled="False">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card x:Name="CardMicro" Grid.Column="0" Background="#1E293B" UniformCornerRadius="16" Margin="10" Padding="0" Cursor="Hand" PreviewMouseLeftButtonDown="CardMicro_Click" materialDesign:ElevationAssist.Elevation="Dp2" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel Margin="25">
                        <Border Background="#10B981" Width="55" Height="55" CornerRadius="27.5" HorizontalAlignment="Center" Margin="0,10,0,15">
                            <materialDesign:PackIcon Kind="FlashOutline" Foreground="#0F172A" Width="35" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Мікрозайм" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Швидкі кошти до зарплати" FontSize="13" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <Separator Background="#334155" Margin="0,0,0,20"/>

                        <TextBlock Text="Кредитний ліміт" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="10 000 ₴" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="CalendarClockOutline" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                            <TextBlock Text="Кількість місяців: " Foreground="#94A3B8" FontSize="13"/>
                            <TextBlock Text="1 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                            <TextBlock Text="Штраф: " Foreground="#EF4444" FontSize="13"/>
                            <TextBlock Text="10% / міс." Foreground="#EF4444" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardStandard" Grid.Column="1" Background="#1E293B" UniformCornerRadius="16" Margin="10" Padding="0" Cursor="Hand" PreviewMouseLeftButtonDown="CardStandard_Click" materialDesign:ElevationAssist.Elevation="Dp8" BorderThickness="2" BorderBrush="Transparent">
                    <Grid>
                        <Border Background="#38BDF8" CornerRadius="16,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" Padding="0,5">
                            <TextBlock Text="НАЙБІЛЬШ ПОПУЛЯРНИЙ" FontSize="11" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="25,40,25,25">
                            <Border Background="#38BDF8" Width="55" Height="55" CornerRadius="27.5" HorizontalAlignment="Center" Margin="0,5,0,15">
                                <materialDesign:PackIcon Kind="CreditCardCheckOutline" Foreground="#0F172A" Width="35" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Стандартний" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Оптимальний вибір на кожен день" FontSize="13" Foreground="#38BDF8" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <Separator Background="#334155" Margin="0,0,0,20"/>

                            <TextBlock Text="Кредитний ліміт" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            <TextBlock Text="50 000 ₴" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="CalendarClockOutline" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                                <TextBlock Text="Кількість місяців: " Foreground="#94A3B8" FontSize="13"/>
                                <TextBlock Text="3 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                                <TextBlock Text="Штраф: " Foreground="#EF4444" FontSize="13"/>
                                <TextBlock Text="8% / міс." Foreground="#EF4444" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card x:Name="CardPremium" Grid.Column="2" Background="#1E293B" UniformCornerRadius="16" Margin="10" Padding="0" Cursor="Hand" PreviewMouseLeftButtonDown="CardPremium_Click" materialDesign:ElevationAssist.Elevation="Dp2" BorderThickness="2" BorderBrush="Transparent">
                    <StackPanel Margin="25">
                        <Border Background="#F59E0B" Width="55" Height="55" CornerRadius="27.5" HorizontalAlignment="Center" Margin="0,10,0,15">
                            <materialDesign:PackIcon Kind="DiamondOutline" Foreground="#0F172A" Width="35" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Преміум" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Для великих покупок" FontSize="13" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <Separator Background="#334155" Margin="0,0,0,20"/>

                        <TextBlock Text="Кредитний ліміт" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="250 000 ₴" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="CalendarClockOutline" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                            <TextBlock Text="Кількість місяців: " Foreground="#94A3B8" FontSize="13"/>
                            <TextBlock Text="6 міс." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0" Width="18" Height="18"/>
                            <TextBlock Text="Штраф: " Foreground="#EF4444" FontSize="13"/>
                            <TextBlock Text="6% / міс." Foreground="#EF4444" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <Border x:Name="PanelInfo" Grid.Row="2" Background="#451A1A" Margin="40,0,40,30" CornerRadius="12" Padding="25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="ShieldAlertOutline" Foreground="#FCA5A5" Margin="0,0,10,0" VerticalAlignment="Center" Width="22" Height="22"/>
                            <TextBlock Text="Увага: Правила користування кредитними коштами" FontWeight="Bold" FontSize="15" Foreground="#FCA5A5" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Кредит надається строком вказаним в плані. Кожного місяця нараховуватимуться відсотки відповідно до вказаного в плані. За несплату кредиту до вказаного терміну його дії, Вас буде додано до чорного списку." TextWrapping="Wrap" Foreground="#F87171" FontSize="13" Margin="0,0,0,8" LineHeight="20"/>
                        <TextBlock Text="За декілька днів до закінчення терміну дії кредиту Ви отримаєте нагадування на Email. Банк не бере відповідальності за непроінформованість про необхідність закриття кредиту, усі Ваші рахунки будуть заблоковані до моменту погашення боргу з нарахованими відсотками." TextWrapping="Wrap" FontWeight="Bold" Foreground="#EF4444" FontSize="13"/>

                        <CheckBox x:Name="ChkAgreement" Content="Я повністю розумію умови та погоджуюсь з ними" Foreground="#E2E8F0" FontSize="14" FontWeight="Bold" Margin="0,20,0,0" Cursor="Hand"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="ЗРОЗУМІЛО" Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" FontSize="15" BorderThickness="0" Margin="10,0,0,0" VerticalAlignment="Center" Height="50" Padding="30,0" materialDesign:ButtonAssist.CornerRadius="12" Click="BtnContinue_Click"/>
                </Grid>
            </Border>

            <Border x:Name="PanelAction" Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Margin="40,0,40,30" CornerRadius="12" Padding="20" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="ОФОРМИТИ ВИБРАНИЙ КРЕДИТ" Click="BtnSubmit_Click" Width="300" Height="50" Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" FontSize="16" materialDesign:ButtonAssist.CornerRadius="12" BorderThickness="0" Margin="0,0,20,0" Cursor="Hand"/>
                    <Button Content="Скасувати" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#94A3B8" BorderBrush="#334155" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="12" Height="50" Padding="30,0" Click="BtnCancel_Click" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>